        "url": "{{baseUrl}}/payments"
      }
    },
    {
      "name": "Payments - Circuit Breaker",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/payments/circuit-breaker"
      }
    }
  ]
}
